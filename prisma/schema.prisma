// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}


enum UserRole {
  SUPER_ADMIN
  INSTRUCTOR
  ADMIN_STAFF
  PARENT
  STUDENT
  GUEST
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(GUEST)
  password      String?
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  
  // Specific Relations
  parentOf      Student[] @relation("ParentStudents")
  students      Student[] @relation("StudentToUser") // If student has their own login

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  dob       DateTime?
  age       Int?
  gender    String?
  grade     String?
  school    String?
  
  // New Fields for Enrollment Form
  additionalInfo Json? // Stores: emergency contacts, tech access, goals, referral info
  
  // Links
  parentId  String
  parent    User     @relation("ParentStudents", fields: [parentId], references: [id])
  
  userId    String?  @unique
  user      User?    @relation("StudentToUser", fields: [userId], references: [id])
  
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  slug        String   @unique
  
  cohorts     Cohort[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cohort {
  id          String   @id @default(cuid())
  name        String   // e.g. "Summer Batch 2026"
  startDate   DateTime
  endDate     DateTime
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  
  instructorId String?
  
  enrollments Enrollment[]
  sessions    CampSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  cohortId  String
  student   Student  @relation(fields: [studentId], references: [id])
  cohort    Cohort   @relation(fields: [cohortId], references: [id])
  
  status    EnrollmentStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([studentId, cohortId])
}

model CampSession {
  id        String   @id @default(cuid())
  cohortId  String
  cohort    Cohort   @relation(fields: [cohortId], references: [id])
  date      DateTime
  topic     String?
  
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(cuid())
  sessionId String
  studentId String
  session   CampSession @relation(fields: [sessionId], references: [id])
  present   Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EnrollmentStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
