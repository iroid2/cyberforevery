generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  INSTRUCTOR
  ADMIN_STAFF
  PARENT
  STUDENT
  GUEST
}

enum EnrollmentStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentRecordStatus {
  PENDING
  SUCCEEDED
  REFUNDED
  FAILED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LearnerRiskLevel {
  ON_TRACK
  WATCHLIST
  AT_RISK
  COMPLETED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssignmentSubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  REVIEWED
  RETURNED
}

enum CertificateStatus {
  ISSUED
  REVOKED
}

model User {
  id                  String                 @id @default(cuid())
  name                String?
  email               String?                @unique
  emailVerified       DateTime?
  image               String?
  role                UserRole               @default(GUEST)
  password            String?
  accounts            Account[]
  sessions            Session[]
  parentOf            Student[]              @relation("ParentStudents")
  students            Student[]              @relation("StudentToUser")
  instructedCohorts   Cohort[]               @relation("InstructorCohorts")
  createdAssignments  Assignment[]           @relation("AssignmentCreator")
  reviewedSubmissions AssignmentSubmission[] @relation("SubmissionReviewer")
  issuedCertificates Certificate[]          @relation("CertificateIssuer")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Student {
  id             String                 @id @default(cuid())
  firstName      String
  lastName       String
  dob            DateTime?
  age            Int?
  gender         String?
  grade          String?
  school         String?
  additionalInfo Json?
  parentId       String
  parent         User                   @relation("ParentStudents", fields: [parentId], references: [id])
  userId         String?                @unique
  user           User?                  @relation("StudentToUser", fields: [userId], references: [id])
  enrollments    Enrollment[]
  attendance     Attendance[]
  submissions    AssignmentSubmission[]
  certificates   Certificate[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  slug        String   @unique
  cohorts     Cohort[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cohort {
  id           String        @id @default(cuid())
  name         String
  startDate    DateTime
  endDate      DateTime
  courseId     String
  course       Course        @relation(fields: [courseId], references: [id])
  instructorId String?
  instructor   User?         @relation("InstructorCohorts", fields: [instructorId], references: [id])
  enrollments  Enrollment[]
  sessions     CampSession[]
  assignments  Assignment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Enrollment {
  id            String           @id @default(cuid())
  studentId     String
  cohortId      String
  student       Student          @relation(fields: [studentId], references: [id])
  cohort        Cohort           @relation(fields: [cohortId], references: [id])
  status        EnrollmentStatus @default(PENDING)
  paymentStatus PaymentStatus    @default(UNPAID)
  payments      Payment[]
  onboardingStatus OnboardingStatus @default(NOT_STARTED)
  learnerRisk      LearnerRiskLevel @default(ON_TRACK)
  approvedAt       DateTime?
  onboardingCompletedAt DateTime?
  completedAt      DateTime?
  finalScore       Int?
  onboardingChecklist OnboardingChecklist?
  certificate         Certificate?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([studentId, cohortId])
}

model OnboardingChecklist {
  id                   String           @id @default(cuid())
  enrollmentId         String           @unique
  enrollment           Enrollment       @relation(fields: [enrollmentId], references: [id])
  profileCompleted     Boolean          @default(false)
  parentConsentSigned  Boolean          @default(false)
  welcomeEmailSent     Boolean          @default(false)
  techSetupVerified    Boolean          @default(false)
  scheduleConfirmed    Boolean          @default(false)
  orientationComplete  Boolean          @default(false)
  firstSessionAttended Boolean          @default(false)
  status               OnboardingStatus @default(NOT_STARTED)
  completedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model CampSession {
  id         String       @id @default(cuid())
  cohortId   String
  cohort     Cohort       @relation(fields: [cohortId], references: [id])
  date       DateTime
  topic      String?
  attendance Attendance[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Attendance {
  id        String      @id @default(cuid())
  sessionId String
  studentId String
  session   CampSession @relation(fields: [sessionId], references: [id])
  student   Student     @relation(fields: [studentId], references: [id])
  present   Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([sessionId, studentId])
}

model Payment {
  id                    String              @id @default(cuid())
  enrollmentId          String
  enrollment            Enrollment          @relation(fields: [enrollmentId], references: [id])
  stripeCheckoutSessionId String            @unique
  stripePaymentIntentId String?
  amount                Int
  currency              String              @default("usd")
  status                PaymentRecordStatus @default(PENDING)
  receiptEmail          String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  createdAt DateTime @default(now())
}

model Assignment {
  id          String       @id @default(cuid())
  cohortId    String
  cohort      Cohort       @relation(fields: [cohortId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  points      Int?
  status      AssignmentStatus @default(PUBLISHED)
  createdById String?
  createdBy   User?        @relation("AssignmentCreator", fields: [createdById], references: [id])
  submissions AssignmentSubmission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AssignmentSubmission {
  id           String                     @id @default(cuid())
  assignmentId String
  assignment   Assignment                 @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student                    @relation(fields: [studentId], references: [id])
  status       AssignmentSubmissionStatus @default(NOT_SUBMITTED)
  note         String?
  fileKey      String?
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  fileType     String?
  submittedAt  DateTime?
  score        Int?
  feedback     String?
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?                      @relation("SubmissionReviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@unique([assignmentId, studentId])
}

model Certificate {
  id                String            @id @default(cuid())
  enrollmentId      String            @unique
  enrollment        Enrollment        @relation(fields: [enrollmentId], references: [id])
  studentId         String
  student           Student           @relation(fields: [studentId], references: [id])
  certificateNumber String            @unique
  verificationCode  String            @unique
  courseTitle       String
  cohortName        String
  issuedById        String?
  issuedBy          User?             @relation("CertificateIssuer", fields: [issuedById], references: [id])
  issuedAt          DateTime          @default(now())
  status            CertificateStatus @default(ISSUED)
  url               String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
