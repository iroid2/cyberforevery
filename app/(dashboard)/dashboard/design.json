{
  "metadata": {
    "version": "1.0.0",
    "description": "Complete design system specifications for the financial dashboard"
  },
  "theme": {
    "colors": {
      "primary": "#16a34a",
      "primary-foreground": "#ffffff",
      "primary-light": "#dcfce7",
      "accent": "#0ea5e9",
      "accent-light": "#e0f2fe",
      "success": "#10b981",
      "warning": "#f59e0b",
      "danger": "#ef4444",
      "background": "#f8fafc",
      "surface": "#ffffff",
      "foreground": "#0f172a",
      "muted": "#94a3b8",
      "muted-light": "#e2e8f0",
      "border": "#e2e8f0"
    },
    "typography": {
      "fontFamily": {
        "sans": "system-ui, -apple-system, sans-serif",
        "mono": "Menlo, Monaco, monospace"
      },
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem"
      },
      "fontWeight": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "lineHeight": {
        "tight": 1.4,
        "normal": 1.6,
        "relaxed": 1.8
      }
    },
    "spacing": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2rem",
      "2xl": "2.5rem",
      "3xl": "3rem"
    },
    "borderRadius": {
      "sm": "0.375rem",
      "md": "0.5rem",
      "lg": "0.75rem",
      "xl": "1rem"
    },
    "shadow": {
      "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
      "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1)"
    },
    "breakpoints": {
      "xs": "0px",
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },
  "components": {
    "sidebar": {
      "widthDesktop": "16rem",
      "widthTablet": "3.5rem",
      "widthMobile": "18rem",
      "heightHeader": "3.5rem",
      "backgroundColor": "#ffffff",
      "borderColor": "#e2e8f0",
      "transitionDuration": "300ms",
      "padding": "1rem",
      "groupSpacing": "0.5rem"
    },
    "header": {
      "height": "4rem",
      "backgroundColor": "#ffffff",
      "borderColor": "#e2e8f0",
      "padding": "1rem 2rem",
      "shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.1)"
    },
    "statsCard": {
      "padding": "1.5rem",
      "borderRadius": "0.75rem",
      "backgroundColor": "#ffffff",
      "borderColor": "#e2e8f0",
      "shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "gridColsDesktop": 3,
      "gridColsTablet": 2,
      "gridColsMobile": 1,
      "gap": "1.5rem"
    },
    "walletCard": {
      "padding": "1.25rem",
      "borderRadius": "0.75rem",
      "backgroundColor": "#ffffff",
      "borderColor": "#e2e8f0",
      "gridColsDesktop": 2,
      "gridColsTablet": 2,
      "gridColsMobile": 1,
      "gap": "1.5rem"
    },
    "chartSection": {
      "padding": "1.5rem",
      "borderRadius": "0.75rem",
      "backgroundColor": "#ffffff",
      "height": "400px",
      "gap": "2rem"
    },
    "transactionList": {
      "padding": "1.5rem",
      "borderRadius": "0.75rem",
      "backgroundColor": "#ffffff",
      "rowHeight": "3.5rem",
      "headerBackgroundColor": "#f8fafc",
      "borderColor": "#e2e8f0"
    },
    "savingsPlanCard": {
      "padding": "1.5rem",
      "borderRadius": "0.75rem",
      "backgroundColor": "#ffffff",
      "borderColor": "#e2e8f0",
      "gridColsDesktop": 2,
      "gridColsTablet": 2,
      "gridColsMobile": 1
    },
    "button": {
      "padding": "0.625rem 1rem",
      "borderRadius": "0.5rem",
      "fontSize": "0.875rem",
      "fontWeight": 600,
      "transitionDuration": "200ms"
    },
    "badge": {
      "padding": "0.25rem 0.75rem",
      "borderRadius": "9999px",
      "fontSize": "0.75rem",
      "fontWeight": 600
    }
  },
  "navigation": {
    "mainMenu": [
      {
        "id": "dashboard",
        "label": "Dashboard",
        "icon": "LayoutDashboard",
        "href": "/dashboard",
        "active": true
      },
      {
        "id": "analytics",
        "label": "Analytics",
        "icon": "BarChart3",
        "href": "/dashboard/analytics",
        "badge": "26"
      },
      {
        "id": "transactions",
        "label": "Transactions",
        "icon": "ArrowRightLeft",
        "href": "/dashboard/transactions"
      },
      {
        "id": "invoices",
        "label": "Invoices",
        "icon": "FileText",
        "href": "/dashboard/invoices"
      }
    ],
    "features": [
      {
        "id": "recurring",
        "label": "Recurring",
        "icon": "RotateCw",
        "href": "/dashboard/recurring",
        "badge": "16"
      },
      {
        "id": "subscriptions",
        "label": "Subscriptions",
        "icon": "CreditCard",
        "href": "/dashboard/subscriptions"
      },
      {
        "id": "feedback",
        "label": "Feedback",
        "icon": "MessageSquare",
        "href": "/dashboard/feedback"
      }
    ],
    "general": [
      {
        "id": "settings",
        "label": "Settings",
        "icon": "Settings",
        "href": "/dashboard/settings"
      },
      {
        "id": "help",
        "label": "Help Desk",
        "icon": "HelpCircle",
        "href": "/dashboard/help"
      },
      {
        "id": "logout",
        "label": "Log out",
        "icon": "LogOut",
        "href": "/logout",
        "isDangerous": true
      }
    ]
  },
  "content": {
    "greeting": "Welcome back {firstName}",
    "subtext": "Monitor and control what happens with your money today for financial health.",
    "sections": {
      "accountBalance": "Account Balance",
      "totalExpenses": "Total Expenses",
      "totalSavings": "Total Savings",
      "myWallet": "My Wallet",
      "overview": "Overview",
      "earnings": "Earnings",
      "recentTransaction": "Recent Transaction",
      "mySavingsPlan": "My Savings Plan",
      "investmentGoal": "Investment Goal",
      "emergencyFund": "Emergency Fund"
    }
  },
  "responsive": {
    "mobile": {
      "sidebarBehavior": "sheet",
      "sidebarWidth": "100%",
      "maxWidth": "640px",
      "statsGridCols": 1,
      "walletGridCols": 1,
      "savingsGridCols": 1,
      "contentPadding": "1rem"
    },
    "tablet": {
      "sidebarBehavior": "icon-only",
      "sidebarWidth": "3.5rem",
      "maxWidth": "768px",
      "statsGridCols": 2,
      "walletGridCols": 2,
      "savingsGridCols": 2,
      "contentPadding": "1.5rem"
    },
    "desktop": {
      "sidebarBehavior": "expanded",
      "sidebarWidth": "16rem",
      "maxWidth": "100%",
      "statsGridCols": 3,
      "walletGridCols": 2,
      "savingsGridCols": 2,
      "contentPadding": "2rem"
    }
  }
}
